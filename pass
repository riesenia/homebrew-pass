#!/bin/bash

config_file="$HOME/.ssh/passbolt.json"
music_file="$(brew --prefix)/share/pass/passbolt.mp3"


if [[ ! -f "$config_file" ]]; then
    echo "Configuration file not found at $config_file."
    echo "Please create the configuration file by running the following command:"
    echo "passbolt configure --config $config_file --serverAddress https://passbolt-instance --userPassword '1234' --userPrivateKeyFile 'keys/privatekey.asc'"
    exit 1
fi

# Function to stop music
finish() {
    if [ -n "$music_pid" ]; then
        kill "$music_pid" > /dev/null 2>&1
        exit 0
    fi
}

afplay $music_file &
music_pid=$!

# Trap Ctrl+C (SIGINT) and stop the music before exiting
trap finish INT

# List resources with the given search string in Name or Username
result=$(passbolt --config "$config_file" list resource --filter "matches(Name, '(?i)$1') || matches(Username, '(?i)$1')")

# Check if result is empty
if [ -z "$result" ]; then
    printf "\n\033[30m\033[41m\033[1mNo resource found!\033[0m\n\n"
    finish
fi

printf '\n\033[35m  ‚Ėą‚Ėą‚Ėď‚Ėą‚Ėą‚Ėą   ‚ĖĄ‚ĖĄ‚ĖĄ        ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą          ‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ    ‚Ėí‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą   ‚Ėą‚Ėą‚Ėď  ‚ĖĄ‚ĖĄ‚ĖĄ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėď ‚Ėź‚Ėą‚Ėą‚ĖĆ \n ‚Ėď‚Ėą‚Ėą‚ĖĎ  ‚Ėą‚Ėą‚Ėí‚Ėí‚Ėą‚Ėą‚Ėą‚Ėą‚ĖĄ    ‚Ėí‚Ėą‚Ėą    ‚Ėí  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą ‚Ėď‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ĖĄ ‚Ėí‚Ėą‚Ėą‚Ėí  ‚Ėą‚Ėą‚Ėí‚Ėď‚Ėą‚Ėą‚Ėí  ‚Ėď  ‚Ėą‚Ėą‚Ėí ‚Ėď‚Ėí ‚Ėź‚Ėą‚Ėą‚ĖĆ \n ‚Ėď‚Ėą‚Ėą‚ĖĎ ‚Ėą‚Ėą‚Ėď‚Ėí‚Ėí‚Ėą‚Ėą  ‚ĖÄ‚Ėą‚ĖĄ  ‚ĖĎ ‚Ėď‚Ėą‚Ėą‚ĖĄ  ‚Ėí‚Ėą‚Ėą    ‚Ėí ‚Ėí‚Ėą‚Ėą‚Ėí ‚ĖĄ‚Ėą‚Ėą‚Ėí‚Ėą‚Ėą‚ĖĎ  ‚Ėą‚Ėą‚Ėí‚Ėí‚Ėą‚Ėą‚ĖĎ  ‚Ėí ‚Ėď‚Ėą‚Ėą‚ĖĎ ‚Ėí‚ĖĎ ‚Ėź‚Ėą‚Ėą‚ĖĆ \n ‚Ėí‚Ėą‚Ėą‚ĖĄ‚Ėą‚Ėď‚Ėí ‚Ėí‚ĖĎ‚Ėą‚Ėą‚ĖĄ‚ĖĄ‚ĖĄ‚ĖĄ‚Ėą‚Ėą   ‚Ėí   ‚Ėą‚Ėą‚ĖĎ ‚Ėď‚Ėą‚Ėą‚ĖĄ  ‚Ėí‚Ėí‚Ėą‚Ėą‚ĖĎ‚Ėą‚ĖÄ  ‚Ėí‚Ėą‚Ėą   ‚Ėą‚Ėą‚ĖĎ‚Ėí‚Ėą‚Ėą‚ĖĎ  ‚ĖĎ ‚Ėď‚Ėą‚Ėą‚Ėď ‚ĖĎ  ‚Ėď‚Ėą‚Ėą‚Ėí \n ‚Ėí‚Ėą‚Ėą‚Ėí ‚ĖĎ  ‚ĖĎ ‚Ėď‚Ėą   ‚Ėď‚Ėą‚Ėą‚Ėí‚Ėí‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėí  ‚Ėí   ‚Ėą‚Ėą‚Ėí‚ĖĎ‚Ėď‚Ėą  ‚ĖÄ‚Ėą‚Ėď‚ĖĎ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėď‚Ėí‚ĖĎ‚ĖĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėí‚Ėí‚Ėą‚Ėą‚Ėí ‚ĖĎ  ‚Ėí‚ĖĄ‚ĖĄ  \n ‚Ėí‚Ėď‚Ėí‚ĖĎ ‚ĖĎ  ‚ĖĎ ‚Ėí‚Ėí   ‚Ėď‚Ėí‚Ėą‚ĖĎ‚Ėí ‚Ėí‚Ėď‚Ėí ‚Ėí ‚Ėí‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėí‚ĖĎ‚ĖĎ‚Ėí‚Ėď‚Ėą‚Ėą‚Ėą‚ĖÄ‚Ėí‚ĖĎ ‚Ėí‚ĖĎ‚Ėí‚ĖĎ‚Ėí‚ĖĎ ‚ĖĎ ‚Ėí‚ĖĎ‚Ėď  ‚ĖĎ‚Ėí ‚ĖĎ‚ĖĎ    ‚ĖĎ‚ĖÄ‚ĖÄ‚Ėí \n ‚ĖĎ‚Ėí ‚ĖĎ       ‚Ėí   ‚Ėí‚Ėí ‚ĖĎ‚ĖĎ ‚ĖĎ‚Ėí  ‚ĖĎ ‚Ėí ‚Ėí‚Ėď‚Ėí ‚Ėí ‚ĖĎ‚Ėí‚ĖĎ‚Ėí   ‚ĖĎ   ‚ĖĎ ‚Ėí ‚Ėí‚ĖĎ ‚ĖĎ ‚ĖĎ ‚Ėí  ‚ĖĎ  ‚ĖĎ     ‚ĖĎ  ‚ĖĎ \n ‚ĖĎ‚ĖĎ         ‚ĖĎ   ‚Ėí   ‚ĖĎ  ‚ĖĎ    ‚ĖĎ ‚ĖĎ‚Ėí  ‚ĖĎ   ‚ĖĎ    ‚ĖĎ ‚ĖĎ ‚ĖĎ ‚ĖĎ ‚Ėí    ‚ĖĎ ‚ĖĎ   ‚ĖĎ          ‚ĖĎ \n                ‚ĖĎ  ‚ĖĎ        ‚ĖĎ  ‚ĖĎ  ‚ĖĎ   ‚ĖĎ          ‚ĖĎ ‚ĖĎ      ‚ĖĎ  ‚ĖĎ        ‚ĖĎ    \033[0m\n\n'

# Check if any resource is found
count=$(echo "$result" | awk 'NR>1 && NF {count++} END {print count}')

if [ "$count" -eq 0 ]; then
    finish

elif [ "$count" -eq 1 ]; then
    printf "$result\n" | awk 'BEGIN {FS="|"; HFS="   "; OFS="\033[0m\033[2m\033[90m | \033[0m\033[97m"} NR==1 {print "\n   \033[0m\033[2m\033[90m\033[3m" $3 HFS $4 HFS $5 "\033[0m"} NR>1 && NF {print " \033[1m\033[35m" NR-1 " \033[0m\033[97m\033[1m" $3 OFS $4 OFS $5 "\033[0m\n"}'

    # Only one resource found, obtain it
    resource_id=$(echo "$result" | awk -v n="1" 'NR==n+1 {print $1}')

else
    # Multiple resources found, list them and let the user choose
    printf "$result\n" | awk 'BEGIN {FS="|"; HFS="   "; OFS="\033[0m\033[2m\033[90m | \033[0m\033[97m"} NR==1 {print "\n   \033[0m\033[2m\033[90m\033[3m" $3 HFS $4 HFS $5 "\033[0m"} NR>1 && NF {print " \033[1m\033[35m" NR-1 " \033[0m\033[97m\033[1m" $3 OFS $4 OFS $5 "\033[0m"}'

    # Prompt user to choose a number
    read -p $'\n\e[35m\e[1m Enter the number of resource: \033[7m' selected
    printf '\033[0m\n'

    # Validate user input
    if ! [[ "$selected" =~ ^[0-9]+$ ]] || [ "$selected" -lt "1" ] || [ "$selected" -gt "$count" ]; then
        printf " \033[30m\033[41m\033[1mInvalid input. Please enter a valid number!\033[0m\n\n"
        finish
    fi

    # Get the resource ID based on user's choice
    resource_id=$(echo "$result" | awk -v n="$selected" 'NR==n+1 {print $1}')
fi

# Obtain the selected resource as JSON (v0.5.0 exposes the full secret, incl. TOTP)
json=$(passbolt --config "$config_file" get resource --id "$resource_id" --json)

password=$(echo "$json" | jq -r '.password // empty')
totp_seed=$(echo "$json" | jq -r '.secret.totp.secret_key // empty')

# If the resource has a TOTP secret, compute the current code locally
totp_code=""
if [ -n "$totp_seed" ]; then
    if ! command -v oathtool > /dev/null 2>&1; then
        printf " \033[30m\033[43m\033[1moathtool not found ‚ÄĒ run: brew install oath-toolkit\033[0m\n\n"
    else
        totp_period=$(echo "$json" | jq -r '.secret.totp.period // 30')
        totp_digits=$(echo "$json" | jq -r '.secret.totp.digits // 6')
        totp_algo=$(echo "$json"   | jq -r '(.secret.totp.algorithm // "SHA1") | ascii_downcase')
        totp_code=$(oathtool --totp="$totp_algo" --base32 \
            --digits="$totp_digits" --time-step-size="${totp_period}s" "$totp_seed")
        # Seconds remaining in the current TOTP window
        remaining=$(( totp_period - ($(date +%s) % totp_period) ))
    fi
fi

if [ -n "$password" ]; then
    # Password (+ optional TOTP): copy password, show the code on screen
    printf "%s" "$password" | pbcopy
    if [ -n "$totp_code" ]; then
        printf " \033[1m\033[42mPassword copied to clipboard!\033[0m\n"
        printf " \033[1m\033[44m TOTP: %s \033[0m \033[2m\033[90m(%ss left)\033[0m\n\n" "$totp_code" "$remaining"
    else
        printf " \033[1m\033[42mPassword copied to clipboard!\033[0m\n\n"
    fi
elif [ -n "$totp_code" ]; then
    # TOTP-only resource: copy the code straight to the clipboard
    printf "%s" "$totp_code" | pbcopy
    printf " \033[1m\033[44m TOTP code %s copied to clipboard!\033[0m \033[2m\033[90m(%ss left)\033[0m\n\n" "$totp_code" "$remaining"
else
    printf " \033[30m\033[41m\033[1mNo password or TOTP found in this resource!\033[0m\n\n"
fi

finish
